# ============================================================
#  AI Fitness Coach — пример переменных окружения
# ============================================================
#  Скопируйте этот файл в `.env.local` и подставьте свои ключи.
#  На MVP приложение БЕЗ ключей тоже работает: оркестратор LLM
#  автоматически переключается на встроенный детерминированный
#  мок-провайдер, чтобы можно было демонстрировать продукт локально.
# ------------------------------------------------------------

# --- Идентификатор активного провайдера ---
# Возможные значения: "groq" | "openai" | "gemini" | "mock"  (по умолчанию "mock")
LLM_PROVIDER=mock

# --- Groq (https://console.groq.com) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ------------------------------------------------------------

# ============================================================
#  Резерв под будущую архитектуру (НЕ используются на MVP).
#  Закомментированы намеренно — чтобы было видно, куда расти.
# ============================================================
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# DATABASE_URL=                  # PostgreSQL (Prisma / Drizzle)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# TELEGRAM_BOT_TOKEN=
